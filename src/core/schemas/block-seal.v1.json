{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "block_id", "obligations_hash", "inputs"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "block-seal.v1"
    },
    "block_id": {
      "type": "string",
      "pattern": "^block-\\d{4,}$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "obligations_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["adapter_id", "gate_plan", "gate_config", "holdout_tasks"],
      "properties": {
        "adapter_id": {
          "type": "string",
          "minLength": 1
        },
        "gate_plan": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "cmd"],
            "properties": {
              "id": {"type": "string", "minLength": 1},
              "cmd": {"type": "array", "items": {"type": "string"}, "minItems": 1},
              "cwd": {"type": "string"},
              "kind": {"type": "string"}
            }
          }
        },
        "gate_config": {
          "type": "object",
          "additionalProperties": true
        },
        "holdout_tasks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "cmd"],
            "properties": {
              "id": {"type": "string", "minLength": 1},
              "cmd": {"type": "array", "items": {"type": "string"}, "minItems": 1}
            }
          }
        },
        "overrides": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
