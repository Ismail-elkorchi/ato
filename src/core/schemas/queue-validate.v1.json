{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ato://queue-validate.v1.json",
  "title": "ATO Queue Validate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ok",
    "schema_version",
    "count",
    "errors"
  ],
  "properties": {
    "ok": {
      "type": "boolean"
    },
    "schema_version": {
      "const": "queue-validate.v1"
    },
    "count": {
      "type": "integer",
      "minimum": 0
    },
    "errors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/queueValidationError"
      }
    }
  },
  "$defs": {
    "queueValidationError": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "message"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "details": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "instance_path": {
              "type": "string"
            },
            "schema_path": {
              "type": "string"
            },
            "keyword": {
              "type": "string"
            },
            "unexpected_key": {
              "type": "string"
            },
            "allowed_keys": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "guidance": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "example": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
