{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ato://agent-session.v1.json",
  "title": "ATO Agent Session Summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source",
    "session_id",
    "started_at",
    "ended_at",
    "counts",
    "rate_limit_info_present",
    "repo",
    "runtime",
    "token_summary",
    "command_summary",
    "integrity"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "agent-session.v1"
    },
    "source": {
      "type": "string",
      "enum": ["codex"]
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "originator": {
      "type": ["string", "null"]
    },
    "model_provider": {
      "type": ["string", "null"]
    },
    "model": {
      "type": ["string", "null"]
    },
    "cli_version": {
      "type": ["string", "null"]
    },
    "git_commit_hash": {
      "type": ["string", "null"]
    },
    "git_branch": {
      "type": ["string", "null"]
    },
    "cwd_rel": {
      "type": "string"
    },
    "cwd_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "started_at": {
      "anyOf": [
        { "type": "string", "format": "date-time" },
        { "type": "null" }
      ]
    },
    "ended_at": {
      "anyOf": [
        { "type": "string", "format": "date-time" },
        { "type": "null" }
      ]
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "messages_user",
        "messages_assistant",
        "tool_calls",
        "shell_commands",
        "errors"
      ],
      "properties": {
        "messages_user": { "type": "integer", "minimum": 0 },
        "messages_assistant": { "type": "integer", "minimum": 0 },
        "tool_calls": { "type": "integer", "minimum": 0 },
        "shell_commands": { "type": "integer", "minimum": 0 },
        "errors": { "type": "integer", "minimum": 0 }
      }
    },
    "rate_limit_info_present": {
      "type": "boolean"
    },
    "instructions_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "repo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["git_commit_hash", "branch", "cwd_hint"],
      "properties": {
        "git_commit_hash": { "type": ["string", "null"] },
        "branch": { "type": ["string", "null"] },
        "cwd_hint": { "type": ["string", "null"] }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model",
        "cli_version",
        "originator",
        "sandbox_mode",
        "approval_policy"
      ],
      "properties": {
        "model": { "type": ["string", "null"] },
        "cli_version": { "type": ["string", "null"] },
        "originator": { "type": ["string", "null"] },
        "sandbox_mode": { "type": ["string", "null"] },
        "approval_policy": { "type": ["string", "null"] }
      }
    },
    "token_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["measurement_method"],
      "properties": {
        "input_tokens": { "type": "number", "minimum": 0 },
        "cached_input_tokens": { "type": "number", "minimum": 0 },
        "output_tokens": { "type": "number", "minimum": 0 },
        "reasoning_output_tokens": { "type": "number", "minimum": 0 },
        "total_tokens": { "type": "number", "minimum": 0 },
        "context_window": { "type": "number", "minimum": 0 },
        "measurement_method": {
          "type": "string",
          "enum": ["max_total", "sum_deltas", "missing"]
        }
      }
    },
    "rate_limit_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["has_credits"],
      "properties": {
        "primary_used_percent": { "type": "number", "minimum": 0 },
        "secondary_used_percent": { "type": "number", "minimum": 0 },
        "has_credits": { "type": "boolean" }
      }
    },
    "command_summary": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "command_hash"],
        "properties": {
          "kind": { "type": "string" },
          "command_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "exit_code": { "type": "number" },
          "output_bytes": { "type": "number", "minimum": 0 }
        }
      }
    },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_file_hash", "redaction_profile_id", "warnings"],
      "properties": {
        "source_file_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "redaction_profile_id": { "type": "string" },
        "warnings": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
