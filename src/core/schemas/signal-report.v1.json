{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ato://signal-report.v1.json",
  "title": "ATO Signal Report",
  "type": "object",
  "additionalProperties": false,
  "required": ["source", "period", "counts", "totals", "averages"],
  "properties": {
    "source": {
      "type": "string",
      "enum": ["codex"]
    },
    "period": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["from", "to"],
          "properties": {
            "from": {
              "anyOf": [
                { "type": "string", "format": "date-time" },
                { "type": "null" }
              ]
            },
            "to": {
              "anyOf": [
                { "type": "string", "format": "date-time" },
                { "type": "null" }
              ]
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["block_id"],
          "properties": {
            "block_id": { "type": "string" }
          }
        }
      ]
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sessions_total"],
      "properties": {
        "sessions_total": { "type": "integer", "minimum": 0 }
      }
    },
    "totals": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input_tokens",
        "output_tokens",
        "cached_input_tokens",
        "total_tokens",
        "context_window",
        "tool_calls_count",
        "error_count"
      ],
      "properties": {
        "input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 },
        "cached_input_tokens": { "type": "integer", "minimum": 0 },
        "total_tokens": { "type": "integer", "minimum": 0 },
        "context_window": { "type": "integer", "minimum": 0 },
        "tool_calls_count": { "type": "integer", "minimum": 0 },
        "error_count": { "type": "integer", "minimum": 0 },
        "latency_ms": { "type": "number", "minimum": 0 }
      }
    },
    "averages": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input_tokens",
        "output_tokens",
        "cached_input_tokens",
        "total_tokens",
        "context_window",
        "tool_calls_count",
        "error_count"
      ],
      "properties": {
        "input_tokens": { "type": "number", "minimum": 0 },
        "output_tokens": { "type": "number", "minimum": 0 },
        "cached_input_tokens": { "type": "number", "minimum": 0 },
        "total_tokens": { "type": "number", "minimum": 0 },
        "context_window": { "type": "number", "minimum": 0 },
        "tool_calls_count": { "type": "number", "minimum": 0 },
        "error_count": { "type": "number", "minimum": 0 },
        "latency_ms": { "type": "number", "minimum": 0 }
      }
    },
    "buckets": {
      "type": "object",
      "additionalProperties": true
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
