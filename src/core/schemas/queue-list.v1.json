{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ato://queue-list.v1.json",
  "title": "ATO Queue List",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ok",
    "schema_version",
    "count",
    "items"
  ],
  "properties": {
    "ok": {
      "type": "boolean",
      "const": true
    },
    "schema_version": {
      "const": "queue-list.v1"
    },
    "count": {
      "type": "integer",
      "minimum": 0
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/queueSummary"
      }
    }
  },
  "$defs": {
    "queueSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "status",
        "priority",
        "tags",
        "target",
        "owner"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^BL-\\d{4,}$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "queued",
            "active",
            "blocked",
            "done",
            "dropped"
          ]
        },
        "priority": {
          "oneOf": [
            {
              "type": "string",
              "enum": [
                "P0",
                "P1",
                "P2",
                "P3",
                "P4"
              ]
            },
            {
              "type": "integer",
              "minimum": 0,
              "maximum": 4
            }
          ]
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "target": {
          "$ref": "#/$defs/queueTarget"
        },
        "owner": {
          "anyOf": [
            {
              "type": "null"
            },
            {
              "type": "string"
            }
          ]
        }
      }
    },
    "queueTarget": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "selector": {
          "type": "string",
          "enum": [
            "exact",
            "range",
            "milestone",
            "unbounded"
          ]
        },
        "kind": {
          "type": "string",
          "enum": [
            "exact",
            "range",
            "milestone",
            "unbounded"
          ]
        },
        "value": {
          "type": "string"
        }
      },
      "anyOf": [
        {
          "type": "object",
          "required": [
            "selector"
          ],
          "properties": {
            "selector": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "type": "string"
            }
          }
        }
      ]
    }
  }
}
