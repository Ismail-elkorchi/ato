{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ato://blackboard.v1.json",
  "title": "ATO Blackboard State",
  "type": "object",
  "additionalProperties": false,
  "required": ["version"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "signals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ts", "summary"],
        "properties": {
          "ts": {
            "type": "string",
            "format": "date-time"
          },
          "kind": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
