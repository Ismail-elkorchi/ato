{
  "name": "@ismail-elkorchi/ato",
  "version": "0.1.0",
  "description": "Agent Task Orchestrator (ATO) - deterministic CLI + protocol",
  "private": false,
  "type": "module",
  "bin": {
    "ato": "dist/cli/main.js"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "check:path-hygiene": "node scripts/check-path-hygiene.mjs --json",
    "lint": "eslint .",
    "format": "prettier . --check",
    "prepublishOnly": "npm run build",
    "test": "npm run build && node scripts/parallel-runner.mjs test/*.test.js test/holdout/*.test.js"
  },
  "files": [
    "dist",
    "templates",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "ajv": "^8.17.1",
    "tiktoken": "^1.0.21"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.0.3",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^16.5.0",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.1"
  }
}
